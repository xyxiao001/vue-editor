{
  "name": "vue-editor-prose-kit",
  "version": "0.2.0",
  "description": "A simple and nice rich text editor component for Vue 3",
  "keywords": [
    "vue",
    "editor",
    "rich-text-editor",
    "vue-editor",
    "vue-component",
    "vue-editor-prose-kit"
  ],
  "main": "./dist/vue-editor-prose-kit.umd.cjs",
  "module": "./dist/vue-editor-prose-kit.js",
  "exports": {
    ".": {
      "import": "./dist/vue-editor-prose-kit.js",
      "require": "./dist/vue-editor-prose-kit.umd.cjs"
    },
    "./style.css": "./dist/vue-editor-prose-kit.css"
  },
  "files": [
    "dist",
    "lib",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyxiao001/vue-editor.git"
  },
  "author": "goodboy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/xyxiao001/vue-editor/issues"
  },
  "homepage": "https://github.com/xyxiao001/vue-editor#readme",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release:check": "npm run build && npm run docs:build && npm publish --dry-run --registry=https://registry.npmjs.org",
    "release:npm": "npm publish --access public --registry=https://registry.npmjs.org",
    "vercel:build": "npm run docs:build",
    "vercel:deploy": "npx vercel --yes",
    "vercel:deploy:prod": "npx vercel --prod --yes",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "rimraf": "^6.1.3",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.31"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.1",
    "@tiptap/extension-underline": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@tiptap/vue-3": "^3.22.1",
    "dompurify": "^3.3.3",
    "lowlight": "^3.3.0"
  }
}
